#Circular Linked List: Deleting the elements at the start

Explanation:
1. The program creates a circular linked list where the last node points back to the first node (head).
2. In deleteStart(), it first checks whether the list is empty or contains only one node.
3. It then finds the last node, moves head to the next node, and links the last node to the new head.
4. Finally, the old first node is deleted using free() to release memory.

#include <stdio.h>
#include <stdlib.h>

// Structure for Circular Linked List Node
struct Node {
    int data;
    struct Node* next;
};

struct Node* head = NULL;

// Function to insert node at the end
void insertEnd(int value) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = value;

    // If the list is empty
    if (head == NULL) {
        head = newNode;
        newNode->next = head;
        return;
    }

    struct Node* temp = head;

    // Traverse to last node
    while (temp->next != head) {
        temp = temp->next;
    }

    temp->next = newNode;
    newNode->next = head;
}

// Function to delete node from start
void deleteStart() {

    // If list is empty
    if (head == NULL) {
        printf("List is empty\n");
        return;
    }

    // If only one node exists
    if (head->next == head) {
        free(head);
        head = NULL;
        return;
    }

    struct Node* temp = head;
    struct Node* last = head;

    // Find last node
    while (last->next != head) {
        last = last->next;
    }

    // Move head to next node
    head = head->next;

    // Last node points to new head
    last->next = head;

    // Delete old head
    free(temp);
}

// Function to display circular linked list
void display() {

    if (head == NULL) {
        printf("List is empty\n");
        return;
    }

    struct Node* temp = head;

    printf("Circular Linked List: ");

    do {
        printf("%d ", temp->data);
        temp = temp->next;
    } while (temp != head);

    printf("\n");
}

// Main function
int main() {

    insertEnd(10);
    insertEnd(20);
    insertEnd(30);
    insertEnd(40);

    printf("Before deletion:\n");
    display();

    deleteStart();

    printf("After deleting from start:\n");
    display();

    return 0;
}

